{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ESNext"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noEmit": true
  },
  // worker-configuration.d.ts is generated by `wrangler types` and provides
  // both the Env interface and all Workers runtime globals.
  "include": ["src/**/*.ts", "worker-configuration.d.ts"]
}
